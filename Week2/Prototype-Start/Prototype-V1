<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CybShield - 2FA Adventure!</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --sky: #00c9ff;
    --sky2: #92effd;
    --yellow: #FFD700;
    --green: #2ecc40;
    --green2: #27ae60;
    --pink: #ff6eb4;
    --purple: #a855f7;
    --orange: #ff7f11;
    --white: #fff;
    --dark: #1a1a2e;
    --card: rgba(255,255,255,0.18);
    --shadow: 0 8px 32px rgba(0,0,0,0.18);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Nunito', sans-serif;
    background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  .stars { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
  .star {
    position: absolute;
    border-radius: 50%;
    background: #fff;
    animation: twinkle 2s infinite alternate;
  }
  @keyframes twinkle { from { opacity:.2; transform:scale(1); } to { opacity:1; transform:scale(1.4); } }

  .bubble {
    position: fixed;
    border-radius: 50%;
    opacity: 0.12;
    animation: floatUp linear infinite;
    pointer-events: none;
    z-index: 0;
  }
  @keyframes floatUp {
    0%   { transform: translateY(100vh) scale(1);   opacity: .12; }
    100% { transform: translateY(-200px) scale(1.3); opacity: 0;   }
  }

  .wrapper {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 16px 120px;
  }

  .title-wrap {
    margin-top: 28px;
    text-align: center;
    animation: popIn .8s cubic-bezier(.36,1.6,.4,1) both;
  }
  @keyframes popIn { from { opacity:0; transform:scale(.5) translateY(-40px); } to { opacity:1; transform:none; } }

  .title-main {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(3rem, 10vw, 6rem);
    background: linear-gradient(90deg, #FFD700, #ff6eb4, #00c9ff, #2ecc40, #FFD700);
    background-size: 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s linear infinite;
    text-shadow: none;
    line-height: 1;
  }
  @keyframes shimmer { 0%{background-position:0%} 100%{background-position:300%} }

  .title-sub {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(1rem, 3vw, 1.6rem);
    color: var(--sky2);
    letter-spacing: 2px;
    margin-top: 4px;
    text-shadow: 0 0 12px #00c9ff88;
  }

  .shield-icon {
    font-size: clamp(2.5rem, 6vw, 4rem);
    display: inline-block;
    animation: spin 6s linear infinite;
    filter: drop-shadow(0 0 12px #FFD700);
  }
  @keyframes spin { 0%{transform:rotate(-10deg)} 50%{transform:rotate(10deg)} 100%{transform:rotate(-10deg)} }

  .badge-2fa {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #ff6eb4, #a855f7);
    color: #fff;
    font-family: 'Fredoka One', cursive;
    font-size: 1.1rem;
    padding: 6px 20px;
    border-radius: 50px;
    margin: 10px auto 0;
    box-shadow: 0 4px 18px #a855f788;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.05)} }

  .score-section {
    width: 100%;
    max-width: 560px;
    margin: 22px auto 0;
    animation: popIn .9s .2s both;
  }
  .score-label {
    font-family: 'Fredoka One', cursive;
    color: var(--yellow);
    font-size: 1.2rem;
    text-align: center;
    margin-bottom: 6px;
    text-shadow: 0 0 8px #FFD70088;
  }
  .score-track {
    background: rgba(255,255,255,0.12);
    border-radius: 50px;
    height: 28px;
    border: 2px solid #FFD70055;
    overflow: hidden;
    position: relative;
  }
  .score-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #FFD700, #ff6eb4, #00c9ff);
    border-radius: 50px;
    transition: width 1s cubic-bezier(.36,1.6,.4,1);
    position: relative;
  }
  .score-fill::after {
    content: '';
    position: absolute;
    right: 0; top: 0; bottom: 0;
    width: 20px;
    background: rgba(255,255,255,0.4);
    border-radius: 50%;
    filter: blur(4px);
  }
  .score-value {
    position: absolute;
    right: 10px; top: 50%;
    transform: translateY(-50%);
    font-family: 'Fredoka One', cursive;
    font-size: 1rem;
    color: #fff;
    text-shadow: 0 1px 4px #0008;
  }

  .reward-section {
    width: 100%;
    max-width: 560px;
    margin: 18px auto 0;
    background: rgba(255,255,255,0.07);
    border: 2px solid #FFD70044;
    border-radius: 20px;
    padding: 14px 20px;
    animation: popIn 1s .3s both;
  }
  .reward-title {
    font-family: 'Fredoka One', cursive;
    color: var(--yellow);
    font-size: 1.1rem;
    margin-bottom: 10px;
    text-align: center;
  }
  .reward-badges {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .reward-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    background: rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 8px 14px;
    border: 2px solid transparent;
    transition: all .3s;
    cursor: default;
  }
  .reward-badge.earned { border-color: #FFD700; background: rgba(255,215,0,0.15); }
  .reward-badge .badge-icon { font-size: 1.8rem; }
  .reward-badge .badge-name { font-size: 0.72rem; font-weight: 700; color: #fff; }
  .reward-badge.earned .badge-name { color: var(--yellow); }
  .reward-bar-wrap { margin-top: 10px; }
  .reward-bar-label { font-size: .82rem; color: #aaa; margin-bottom: 4px; text-align:center; }
  .reward-bar-track {
    background: rgba(255,255,255,0.1);
    border-radius: 50px;
    height: 14px;
    overflow: hidden;
  }
  .reward-bar-fill {
    height: 100%;
    width: 20%;
    background: linear-gradient(90deg, #FFD700, #ff6eb4);
    border-radius: 50px;
    transition: width 1.2s .5s cubic-bezier(.36,1.6,.4,1);
  }

  .char-section {
    width: 100%;
    max-width: 700px;
    margin: 22px auto 0;
    animation: popIn 1s .4s both;
  }
  .char-title {
    font-family: 'Fredoka One', cursive;
    color: var(--sky);
    font-size: 1.3rem;
    text-align: center;
    margin-bottom: 14px;
    text-shadow: 0 0 10px #00c9ff88;
  }
  .char-grid {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .char-card {
    width: 110px;
    background: rgba(255,255,255,0.08);
    border: 3px solid transparent;
    border-radius: 20px;
    padding: 12px 8px 10px;
    text-align: center;
    cursor: pointer;
    transition: all .35s cubic-bezier(.36,1.6,.4,1);
    position: relative;
    overflow: hidden;
  }
  .char-card:hover { transform: translateY(-8px) scale(1.06); background: rgba(255,255,255,0.15); }
  .char-card.selected {
    border-color: var(--yellow);
    background: rgba(255,215,0,0.12);
    transform: translateY(-10px) scale(1.08);
    box-shadow: 0 0 24px #FFD70066;
  }
  .char-card.selected::after {
    content: '✓';
    position: absolute;
    top: 6px; right: 8px;
    font-size: .85rem;
    color: var(--yellow);
    font-weight: 900;
  }
  .char-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    margin: 0 auto 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.6rem;
    position: relative;
    overflow: hidden;
  }
  .char-name {
    font-family: 'Fredoka One', cursive;
    font-size: .9rem;
    color: #fff;
    margin-bottom: 2px;
  }
  .char-role {
    font-size: .68rem;
    color: #aaa;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .char-card.selected .char-name { color: var(--yellow); }
  .anime-face { width: 100%; height: 100%; }

  .overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10,10,30,0.82);
    backdrop-filter: blur(6px);
    z-index: 100;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .overlay.active { display: flex; }

  .modal {
    background: linear-gradient(135deg, #1a1a3e, #2d1b69);
    border: 3px solid var(--yellow);
    border-radius: 28px;
    padding: 36px 32px;
    max-width: 480px;
    width: 100%;
    text-align: center;
    animation: modalPop .5s cubic-bezier(.36,1.6,.4,1) both;
    box-shadow: 0 0 60px #FFD70033;
  }
  @keyframes modalPop { from{opacity:0;transform:scale(.6)} to{opacity:1;transform:none} }
  .modal-icon { font-size: 3rem; margin-bottom: 12px; display:block; }
  .modal-title {
    font-family: 'Fredoka One', cursive;
    font-size: 1.8rem;
    color: var(--yellow);
    margin-bottom: 12px;
  }
  .modal-body {
    font-size: 1.05rem;
    color: #e0e0ff;
    line-height: 1.7;
    margin-bottom: 22px;
  }
  .modal-body strong { color: var(--sky); }
  .modal-close {
    background: linear-gradient(135deg, var(--yellow), #ff9f00);
    color: #1a1a2e;
    font-family: 'Fredoka One', cursive;
    font-size: 1.1rem;
    border: none;
    border-radius: 50px;
    padding: 12px 36px;
    cursor: pointer;
    transition: transform .2s;
  }
  .modal-close:hover { transform: scale(1.07); }

  .feedback-list { text-align: left; margin: 0 0 18px; padding: 0; list-style: none; }
  .feedback-list li {
    background: rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 10px 14px;
    margin-bottom: 8px;
    font-size: .95rem;
    color: #e0e0ff;
    border-left: 4px solid var(--sky);
  }
  .feedback-list li .fb-score { font-family: 'Fredoka One', cursive; color: var(--yellow); float: right; }

  .bottom-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 16px 24px 20px;
    z-index: 50;
    background: linear-gradient(to top, rgba(10,10,30,.9) 60%, transparent);
    pointer-events: none;
  }
  .bottom-bar > * { pointer-events: all; }

  .btn-how {
    background: linear-gradient(135deg, #FFD700, #ff9f00);
    color: #1a1a2e;
    font-family: 'Fredoka One', cursive;
    font-size: 1.05rem;
    border: none;
    border-radius: 50px;
    padding: 14px 26px;
    cursor: pointer;
    box-shadow: 0 6px 20px #FFD70066;
    transition: transform .2s, box-shadow .2s;
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 44px;
    min-height: 44px;
  }
  .btn-how:hover { transform: translateY(-4px) scale(1.05); box-shadow: 0 10px 28px #FFD700aa; }

  .btn-feedback {
    background: rgba(255,255,255,0.1);
    color: #fff;
    font-family: 'Fredoka One', cursive;
    font-size: 0.9rem;
    border: 2px solid rgba(255,255,255,0.25);
    border-radius: 50px;
    padding: 10px 20px;
    cursor: pointer;
    transition: all .2s;
    min-width: 44px;
    min-height: 44px;
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
  }
  .btn-feedback:hover { background: rgba(255,255,255,0.18); transform: translateX(-50%) scale(1.05); }

  .btn-start {
    background: linear-gradient(135deg, #2ecc40, #27ae60);
    color: #fff;
    font-family: 'Fredoka One', cursive;
    font-size: 1.1rem;
    border: none;
    border-radius: 50px;
    padding: 14px 30px;
    cursor: pointer;
    box-shadow: 0 6px 20px #2ecc4066;
    transition: transform .2s, box-shadow .2s;
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 44px;
    min-height: 44px;
    animation: glowGreen 2s ease-in-out infinite;
  }
  @keyframes glowGreen { 0%,100%{box-shadow:0 6px 20px #2ecc4066} 50%{box-shadow:0 6px 36px #2ecc40cc} }
  .btn-start:hover { transform: translateY(-4px) scale(1.05); }

  @media (max-width: 520px) {
    .char-card { width: 90px; }
    .char-avatar { width: 58px; height: 58px; font-size: 2rem; }
    .modal { padding: 24px 18px; }
    .btn-how, .btn-start { padding: 12px 18px; font-size:.95rem; }
  }
</style>
</head>
<body>

<div class="stars" id="stars"></div>
<div id="bubbles"></div>

<div class="wrapper">

  <div class="title-wrap">
    <span class="shield-icon">🛡️</span>
    <div class="title-main">CybShield</div>
    <div class="title-sub">✨ Cyber Security Adventure! ✨</div>
    <div class="badge-2fa">🔐 2FA HERO QUEST</div>
  </div>

  <div class="score-section">
    <div class="score-label">⭐ Your Score</div>
    <div class="score-track">
      <div class="score-fill" id="scoreFill"></div>
      <span class="score-value" id="scoreValue">0 / 100</span>
    </div>
  </div>

  <div class="reward-section">
    <div class="reward-title">🏆 Reward Badges</div>
    <div class="reward-badges">
      <div class="reward-badge earned">
        <span class="badge-icon">🌟</span>
        <span class="badge-name">Starter</span>
      </div>
      <div class="reward-badge">
        <span class="badge-icon">🔓</span>
        <span class="badge-name">Breaker</span>
      </div>
      <div class="reward-badge">
        <span class="badge-icon">🛡️</span>
        <span class="badge-name">Shield</span>
      </div>
      <div class="reward-badge">
        <span class="badge-icon">🥷</span>
        <span class="badge-name">Ninja</span>
      </div>
      <div class="reward-badge">
        <span class="badge-icon">👑</span>
        <span class="badge-name">Legend</span>
      </div>
    </div>
    <div class="reward-bar-wrap">
      <div class="reward-bar-label">Progress to next badge</div>
      <div class="reward-bar-track">
        <div class="reward-bar-fill" id="rewardFill"></div>
      </div>
    </div>
  </div>

  <div class="char-section">
    <div class="char-title">🎮 Choose Your Hero!</div>
    <div class="char-grid" id="charGrid">

      <!-- PRIKSHA (girl – Miku style) -->
      <div class="char-card" data-char="priksha" onclick="selectChar(this)">
        <div class="char-avatar" style="background:linear-gradient(135deg,#00c9ff,#6ee7f7)">
          <svg class="anime-face" viewBox="0 0 72 72" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="36" cy="40" rx="20" ry="22" fill="#FDDBB4"/>
            <ellipse cx="36" cy="24" rx="20" ry="14" fill="#39C5BB"/>
            <ellipse cx="14" cy="44" rx="7" ry="18" fill="#39C5BB" transform="rotate(-15 14 44)"/>
            <ellipse cx="58" cy="44" rx="7" ry="18" fill="#39C5BB" transform="rotate(15 58 44)"/>
            <ellipse cx="28" cy="38" rx="5" ry="6" fill="#1a90d0"/>
            <ellipse cx="44" cy="38" rx="5" ry="6" fill="#1a90d0"/>
            <circle cx="27" cy="37" r="2" fill="#fff"/>
            <circle cx="43" cy="37" r="2" fill="#fff"/>
            <path d="M30 50 Q36 56 42 50" stroke="#e07070" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <ellipse cx="23" cy="45" rx="4" ry="2.5" fill="#ffaaaa" opacity=".5"/>
            <ellipse cx="49" cy="45" rx="4" ry="2.5" fill="#ffaaaa" opacity=".5"/>
          </svg>
        </div>
        <div class="char-name">Priksha</div>
        <div class="char-role">👧 Cyber Mage</div>
      </div>

      <!-- PAWAN (boy – Hiroto style) -->
      <div class="char-card" data-char="pawan" onclick="selectChar(this)">
        <div class="char-avatar" style="background:linear-gradient(135deg,#ff7f11,#ffcc44)">
          <svg class="anime-face" viewBox="0 0 72 72" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="36" cy="40" rx="20" ry="22" fill="#FDDBB4"/>
            <ellipse cx="36" cy="22" rx="20" ry="13" fill="#e85d00"/>
            <polygon points="18,22 14,8 22,20" fill="#e85d00"/>
            <polygon points="28,16 26,4 33,16" fill="#e85d00"/>
            <polygon points="36,14 35,2 40,14" fill="#e85d00"/>
            <polygon points="44,16 46,4 40,16" fill="#e85d00"/>
            <polygon points="54,22 58,8 50,20" fill="#e85d00"/>
            <ellipse cx="28" cy="38" rx="5" ry="5.5" fill="#3a5fa0"/>
            <ellipse cx="44" cy="38" rx="5" ry="5.5" fill="#3a5fa0"/>
            <circle cx="27.5" cy="37" r="1.8" fill="#fff"/>
            <circle cx="43.5" cy="37" r="1.8" fill="#fff"/>
            <path d="M30 50 Q36 55 42 50" stroke="#e07070" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <ellipse cx="23" cy="44" rx="4" ry="2" fill="#ffaaaa" opacity=".45"/>
            <ellipse cx="49" cy="44" rx="4" ry="2" fill="#ffaaaa" opacity=".45"/>
          </svg>
        </div>
        <div class="char-name">Pawan</div>
        <div class="char-role">👦 Code Warrior</div>
      </div>

      <!-- MISHA (girl – Mikasa style) -->
      <div class="char-card" data-char="misha" onclick="selectChar(this)">
        <div class="char-avatar" style="background:linear-gradient(135deg,#ff6eb4,#ffb3d9)">
          <svg class="anime-face" viewBox="0 0 72 72" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="36" cy="41" rx="19" ry="21" fill="#FDDBB4"/>
            <rect x="16" y="16" width="40" height="18" rx="10" fill="#2c2c3e"/>
            <rect x="13" y="24" width="8" height="28" rx="4" fill="#2c2c3e"/>
            <rect x="51" y="24" width="8" height="28" rx="4" fill="#2c2c3e"/>
            <ellipse cx="28" cy="38" rx="5" ry="5" fill="#5b3a29"/>
            <ellipse cx="44" cy="38" rx="5" ry="5" fill="#5b3a29"/>
            <circle cx="27.5" cy="37" r="1.6" fill="#fff"/>
            <circle cx="43.5" cy="37" r="1.6" fill="#fff"/>
            <line x1="23" y1="31" x2="33" y2="33" stroke="#333" stroke-width="2" stroke-linecap="round"/>
            <line x1="39" y1="33" x2="49" y2="31" stroke="#333" stroke-width="2" stroke-linecap="round"/>
            <path d="M31 50 Q36 54 41 50" stroke="#c06070" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="char-name">Misha</div>
        <div class="char-role">👧 Shield Guard</div>
      </div>

      <!-- YOSHEPH (boy – Shoyo style) -->
      <div class="char-card" data-char="yosheph" onclick="selectChar(this)">
        <div class="char-avatar" style="background:linear-gradient(135deg,#a855f7,#d8b4fe)">
          <svg class="anime-face" viewBox="0 0 72 72" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="36" cy="40" rx="20" ry="22" fill="#FDDBB4"/>
            <ellipse cx="36" cy="22" rx="21" ry="15" fill="#ff7f11"/>
            <ellipse cx="36" cy="17" rx="16" ry="10" fill="#ff9933"/>
            <circle cx="20" cy="26" r="8" fill="#ff7f11"/>
            <circle cx="52" cy="26" r="8" fill="#ff7f11"/>
            <ellipse cx="28" cy="39" rx="5.5" ry="6" fill="#8855cc"/>
            <ellipse cx="44" cy="39" rx="5.5" ry="6" fill="#8855cc"/>
            <circle cx="27" cy="37.5" r="2.2" fill="#fff"/>
            <circle cx="43" cy="37.5" r="2.2" fill="#fff"/>
            <path d="M29 50 Q36 58 43 50" stroke="#e07070" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <ellipse cx="22" cy="45" rx="4.5" ry="2.5" fill="#ffaaaa" opacity=".5"/>
            <ellipse cx="50" cy="45" rx="4.5" ry="2.5" fill="#ffaaaa" opacity=".5"/>
          </svg>
        </div>
        <div class="char-name">Yosheph</div>
        <div class="char-role">👦 Data Scout</div>
      </div>

      <!-- KRISHNA (boy – Sekita style) -->
      <div class="char-card" data-char="krishna" onclick="selectChar(this)">
        <div class="char-avatar" style="background:linear-gradient(135deg,#2ecc40,#a7f3a0)">
          <svg class="anime-face" viewBox="0 0 72 72" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="36" cy="40" rx="20" ry="22" fill="#FDDBB4"/>
            <ellipse cx="36" cy="22" rx="21" ry="13" fill="#1a1a2e"/>
            <ellipse cx="46" cy="20" rx="14" ry="10" fill="#1a1a2e"/>
            <ellipse cx="42" cy="12" rx="3" ry="6" fill="#1a1a2e"/>
            <ellipse cx="28" cy="38" rx="5" ry="4" fill="#2d6a2d"/>
            <ellipse cx="44" cy="38" rx="5" ry="4" fill="#2d6a2d"/>
            <path d="M23 36 Q28 33 33 36" stroke="#1a1a2e" stroke-width="2" fill="none"/>
            <path d="M39 36 Q44 33 49 36" stroke="#1a1a2e" stroke-width="2" fill="none"/>
            <circle cx="27.5" cy="38" r="1.5" fill="#fff"/>
            <circle cx="43.5" cy="38" r="1.5" fill="#fff"/>
            <path d="M30 50 Q36 56 42 50" stroke="#c06070" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <ellipse cx="23" cy="44" rx="4" ry="2" fill="#ffaaaa" opacity=".4"/>
            <ellipse cx="49" cy="44" rx="4" ry="2" fill="#ffaaaa" opacity=".4"/>
          </svg>
        </div>
        <div class="char-name">Krishna</div>
        <div class="char-role">👦 Cyber Sage</div>
      </div>

    </div>
  </div>

</div>

<div class="bottom-bar">
  <button class="btn-how" onclick="openModal('how')" aria-label="How to Play">❓ How to Play</button>
  <button class="btn-feedback" onclick="openModal('feedback')" aria-label="Feedback">💬 Feedback</button>
  <button class="btn-start" onclick="openModal('start')" aria-label="Start Game">▶ Start!</button>
</div>

<!-- HOW TO PLAY MODAL -->
<div class="overlay" id="howModal">
  <div class="modal">
    <span class="modal-icon">📖</span>
    <div class="modal-title">How to Play!</div>
    <div class="modal-body">
      🎯 <strong>Your Mission:</strong><br>
      You should choose <strong>one correct answer</strong> related to <strong>2FA (Two-Factor Authentication)</strong>!<br><br>
      🔐 <strong>What is 2FA?</strong><br>
      It means using <em>two ways</em> to prove who you are — like a password <strong>AND</strong> a secret code sent to your phone!<br><br>
      ⭐ Answer correctly to earn stars and unlock cool badges!<br>
      🛡️ Protect the cyber world with your hero!
    </div>
    <button class="modal-close" onclick="closeModal('howModal')">Got it! Let's go! 🚀</button>
  </div>
</div>

<!-- START MODAL -->
<div class="overlay" id="startModal">
  <div class="modal">
    <span class="modal-icon">🚀</span>
    <div class="modal-title" id="startTitle">Ready to Play?</div>
    <div class="modal-body" id="startBody">
      Choose your hero first, then embark on the <strong>2FA Adventure!</strong><br><br>
      Protect the cyber world, earn badges, and become a <strong>CybShield Legend!</strong> 🛡️
    </div>
    <button class="modal-close" onclick="closeModal('startModal')">Let's Go! 🎮</button>
  </div>
</div>

<!-- FEEDBACK MODAL -->
<div class="overlay" id="feedbackModal">
  <div class="modal">
    <span class="modal-icon">💬</span>
    <div class="modal-title">Previous Play Feedback</div>
    <ul class="feedback-list">
      <li>🟢 Round 1 — Great job identifying 2FA correctly! <span class="fb-score">20 pts</span></li>
      <li>🔵 Round 2 — You answered 3 out of 5 questions! <span class="fb-score">+15 pts</span></li>
      <li>🟡 Round 3 — Almost! Missed the SMS 2FA question. <span class="fb-score">+10 pts</span></li>
      <li>🟣 Round 4 — Perfect score on the badge round! <span class="fb-score">+25 pts</span></li>
      <li>🔴 Round 5 — Time ran out on question 4. Keep going! <span class="fb-score">+5 pts</span></li>
    </ul>
    <div style="color:#aaa;font-size:.85rem;margin-bottom:16px;">Total: <span style="color:var(--yellow);font-family:'Fredoka One',cursive">75 / 100 pts</span></div>
    <button class="modal-close" onclick="closeModal('feedbackModal')">Thanks! 🌟</button>
  </div>
</div>

<script>
const starsEl = document.getElementById('stars');
for (let i = 0; i < 80; i++) {
  const s = document.createElement('div');
  s.className = 'star';
  const size = Math.random() * 3 + 1;
  s.style.cssText = `width:${size}px;height:${size}px;left:${Math.random()*100}%;top:${Math.random()*100}%;animation-delay:${Math.random()*4}s;animation-duration:${1.5+Math.random()*3}s;`;
  starsEl.appendChild(s);
}

const bubblesEl = document.getElementById('bubbles');
const colors = ['#00c9ff','#ff6eb4','#FFD700','#2ecc40','#a855f7','#ff7f11'];
for (let i = 0; i < 14; i++) {
  const b = document.createElement('div');
  b.className = 'bubble';
  const size = 30 + Math.random() * 80;
  b.style.cssText = `width:${size}px;height:${size}px;left:${Math.random()*100}%;background:${colors[Math.floor(Math.random()*colors.length)]};animation-duration:${8+Math.random()*14}s;animation-delay:${Math.random()*10}s;`;
  bubblesEl.appendChild(b);
}

setTimeout(() => {
  document.getElementById('scoreFill').style.width = '35%';
  document.getElementById('scoreValue').textContent = '35 / 100';
  document.getElementById('rewardFill').style.width = '35%';
}, 600);

let selectedChar = null;
function selectChar(card) {
  document.querySelectorAll('.char-card').forEach(c => c.classList.remove('selected'));
  card.classList.add('selected');
  selectedChar = card.dataset.char;
  document.getElementById('startTitle').textContent = `Hello, ${card.querySelector('.char-name').textContent}! 👋`;
  document.getElementById('startBody').innerHTML = `You've chosen your hero! Ready for the <strong>2FA Adventure!</strong><br><br>Protect the cyber world, earn badges, and become a <strong>CybShield Legend!</strong> 🛡️`;
}

function openModal(type) {
  if (type === 'how')      document.getElementById('howModal').classList.add('active');
  if (type === 'feedback') document.getElementById('feedbackModal').classList.add('active');
  if (type === 'start')    document.getElementById('startModal').classList.add('active');
}
function closeModal(id) {
  document.getElementById(id).classList.remove('active');
}

document.querySelectorAll('.overlay').forEach(o => {
  o.addEventListener('click', e => { if (e.target === o) o.classList.remove('active'); });
});

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.querySelectorAll('.overlay.active').forEach(o => o.classList.remove('active'));
});
</script>
</body>
</html>
